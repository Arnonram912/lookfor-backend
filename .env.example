SECRET_KEY=replace-with-your-secret-key
GMAIL_SENDER_EMAIL=your-email@example.com
GMAIL_APP_PASSWORD=your-app-password
MFA_CODE_EXPIRE_MINUTES=10
LOOKFOR_LOGIN_URL=http://127.0.0.1:8000/login
LOOKFOR_BASE_URL=http://127.0.0.1:8000
ACCOUNT_EMAIL_QUEUE_SIZE=500

# Local SQL Server defaults. For Azure SQL or hosted SQL Server, replace these
# values in your hosting provider's environment variable settings.
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_SERVER=LAPTOP-2QGNEQVD\SQLEXPRESS
DB_NAME=LookForDB
DB_USERNAME=
DB_PASSWORD=
DB_ENCRYPT=no
DB_TRUST_SERVER_CERTIFICATE=yes
DB_FAST_EXECUTEMANY=true
DB_POOL_SIZE=2
DB_MAX_OVERFLOW=1
DB_POOL_TIMEOUT=15

# Bulk registration tuning. Use one hash worker on a single-vCPU plan.
AUTH_HASH_CONCURRENCY=1
BULK_HASH_WORKERS=1
BULK_HASH_CHUNK_SIZE=500
BULK_COMMIT_CHUNK_SIZE=250
MAX_BULK_REGISTRATION_ROWS=1000
CLIP_TORCH_THREADS=1
CLIP_IMAGE_VIEWS=2
CLIP_MAX_INPUT_DIMENSION=768
TOKENIZERS_PARALLELISM=false
OMP_NUM_THREADS=1
MKL_NUM_THREADS=1

# Azure App Service B1: keep one process and cap concurrent in-flight requests.
UVICORN_LIMIT_CONCURRENCY=20
UVICORN_BACKLOG=64
WEBSITES_ENABLE_APP_SERVICE_STORAGE=true

# Use /home/data/uploads with Azure App Service persistent storage enabled.
# Local development defaults to static/uploads when this is left blank.
UPLOAD_FOLDER=

# Required in production so lost/found uploaded images survive deploys.
# Create a free Cloudinary account, then set either CLOUDINARY_URL or the
# three separate values below in your hosting provider environment variables.
IMAGE_STORAGE_PROVIDER=cloudinary
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
