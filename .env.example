SECRET_KEY=replace-with-your-secret-key
GMAIL_SENDER_EMAIL=your-email@example.com
GMAIL_APP_PASSWORD=your-app-password
MFA_CODE_EXPIRE_MINUTES=10

# Local SQL Server defaults. For Azure SQL or hosted SQL Server, replace these
# values in your hosting provider's environment variable settings.
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_SERVER=LAPTOP-2QGNEQVD\SQLEXPRESS
DB_NAME=LookForDB
DB_USERNAME=
DB_PASSWORD=
DB_ENCRYPT=no
DB_TRUST_SERVER_CERTIFICATE=yes

# Required in production so lost/found uploaded images survive deploys.
# Create a free Cloudinary account, then set either CLOUDINARY_URL or the
# three separate values below in your hosting provider environment variables.
IMAGE_STORAGE_PROVIDER=cloudinary
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
